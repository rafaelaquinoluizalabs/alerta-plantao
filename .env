# URL do Incoming Webhook do Google Chat
#GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/XXXX/messages?key=YYYY&token=ZZZZ
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/AAAAjMN59Ck/messages?key=AIzaSyDdI0hCZtE6vySjMm-WEfRq3CPzqKqqsHI&token=TWiu1W_Tum1ljB-p4_ihq5HyLFI9JYtc8MzLKrBijkE

# ID da planilha do Google Sheets
SPREADSHEET_ID=1sJMqySE4QnQjSqz7OJPrHB4sDc7MHoBatbGsIICLHpc

# Caminho para o arquivo de credenciais da Service Account
CREDENTIALS_PATH=./credentials.json

# Nome da aba a ser lida
SHEET_TAB_NAME=HOJE

# Caminho para o JSON com o mapa { "Nome na planilha": "USER_ID" }
# usado para transformar nomes em menções reais (<users/USER_ID>) no Google Chat.
MENTIONS_PATH=./mentions.json

# E-mail do admin do Workspace a ser impersonado pela Service Account
# (domain-wide delegation). Usado APENAS por tools/build_mentions.py para
# resolver e-mails em USER_IDs via Admin SDK Directory API.
ADMIN_EMAIL=admin@suaempresa.com
MENTIONS_BOT_PATH=./mentions-bot.json
CHAT_PROJECT_NUMBER=000000000000
