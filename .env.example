# URL do Incoming Webhook do Google Chat
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/XXXX/messages?key=YYYY&token=ZZZZ

# ID da planilha do Google Sheets
SPREADSHEET_ID=12nm98Sy_HmYtmz5F9mJevUjI4KGDANSonKkgFaIdiQY

# Caminho para o arquivo de credenciais da Service Account
CREDENTIALS_PATH=./credentials.json

# Nome da aba a ser lida
SHEET_TAB_NAME=HOJE

# Caminho para o JSON com o mapa { "Nome na planilha": "USER_ID" }
# usado para transformar nomes em menções reais (<users/USER_ID>) no Google Chat.
MENTIONS_PATH=./mentions.json

# --- VictorOps / Splunk On-Call (tools/ajustar_plantonistas.py) ---
# Credenciais da API do VictorOps.
VICTOROPS_API_ID=
VICTOROPS_API_KEY=
VICTOROPS_ORG_ID=

# (Opcional) Times do VictorOps a consultar, separados por vírgula.
# Se vazio, usa as competências de tools/planilha_map.py.
VICTOROPS_TEAMS=

# (Opcional) Caminho para o bundle de CA corporativa (redes com proxy/cert interno).
# VICTOROPS_CA_BUNDLE=/caminho/para/ca-bundle.pem

# (Opcional) Desativa a verificação TLS — NÃO recomendado. Use só em ambiente controlado.
# VICTOROPS_INSECURE=false