# URL do Incoming Webhook do Google Chat
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/XXXX/messages?key=YYYY&token=ZZZZ

# ID da planilha do Google Sheets
SPREADSHEET_ID=12nm98Sy_HmYtmz5F9mJevUjI4KGDANSonKkgFaIdiQY

# Caminho para o arquivo de credenciais da Service Account
CREDENTIALS_PATH=./credentials.json

# Nome da aba a ser lida
SHEET_TAB_NAME=HOJE

# Caminho para o JSON com o mapa { "Nome na planilha": "USER_ID" }
# usado para transformar nomes em menções reais (<users/USER_ID>) no Google Chat.
MENTIONS_PATH=./mentions.json

# E-mail do admin do Workspace a ser impersonado pela Service Account
# (domain-wide delegation). Usado APENAS por tools/build_mentions.py para
# resolver e-mails em USER_IDs via Admin SDK Directory API.
ADMIN_EMAIL=admin@suaempresa.com

# Caminho do arquivo gerado pelo bot (tools/bot.py) ao capturar os USER_IDs
# de quem manda mensagem para ele. Pode ser apontado em MENTIONS_PATH depois.
MENTIONS_BOT_PATH=./mentions-bot.json

# (Opcional, recomendado) Número do projeto no Google Cloud, usado pelo
# tools/bot.py para validar o token JWT enviado pelo Google Chat.
CHAT_PROJECT_NUMBER=000000000000

# Credenciais OAuth usadas pelo serviço web tools/whoami.py, que permite a
# pessoa descobrir o próprio USER_ID do Google Chat fazendo login com a conta
# Google. Crie um "OAuth client ID" do tipo "Web application" no Cloud Console.
GOOGLE_OAUTH_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=xxxx
OAUTH_REDIRECT_URI=http://localhost:8080/oauth2/callback
# Arquivo gerado incrementalmente pelo whoami.py com nome -> USER_ID de quem acessar.
MENTIONS_WEB_PATH=./mentions-web.json
# Chave para assinar a sessão do Flask (qualquer string aleatória).
FLASK_SECRET_KEY=troque-por-uma-string-aleatoria
